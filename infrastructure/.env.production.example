# ─────────────────────────────────────────────────────────────────────────────
# A TO Z ROUTES — Production Environment Variables
# Copy to .env and fill in all values before deploying
# NEVER commit this file to git
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false

# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ── Database (AWS RDS) ────────────────────────────────────────────────────────
POSTGRES_HOST=your-rds-endpoint.region.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=atozroutes
POSTGRES_USER=atozroutes_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Redis (AWS ElastiCache) ───────────────────────────────────────────────────
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Frontend URLs ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com/api/v1
NEXT_PUBLIC_WS_URL=wss://yourdomain.com/ws

# ── External services ─────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

SENDGRID_API_KEY=SG.your_sendgrid_key_here

TWILIO_ACCOUNT_SID=AC_your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Docker ────────────────────────────────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io/zahikabas
IMAGE_TAG=latest
